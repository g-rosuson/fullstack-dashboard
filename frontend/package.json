{
    "name": "react-authentication",
    "private": true,
    "version": "1.0.0",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "test": "vitest",
        "preview": "vite preview",
        "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" --max-warnings=0 --cache",
        "lint-fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix",
        "lint-styling": "npx stylelint \"**/*.css\" --max-warnings=0",
        "format": "npx prettier . --write --ignore-path ../.prettierignore",
        "scadd": "sh -c 'npx shadcn@latest add \"$@\" && npm run format' --",
        "prepare": "husky install",
        "type-check": "tsc --noEmit",
        "generate-types": "orval --config orval.config.ts"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@fontsource-variable/inter": "^5.2.8",
        "@microsoft/fetch-event-source": "^2.0.1",
        "@tanstack/react-table": "^8.21.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^1.7.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-day-picker": "^9.14.0",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.1.1",
        "shadcn": "^4.1.1",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^3.25.67",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.3.0",
        "@commitlint/config-conventional": "^19.2.2",
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.19.15",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "8.57.0",
        "eslint-plugin-promise": "6.1.1",
        "eslint-plugin-react": "^7.37.3",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-simple-import-sort": "12.0.0",
        "eslint-plugin-sonarjs": "1.0.3",
        "eslint-plugin-unicorn": "51.0.1",
        "globals": "^15.14.0",
        "husky": "^9.0.11",
        "jsdom": "^26.0.0",
        "jwt-decode": "^4.0.0",
        "orval": "6.29.1",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.19.0",
        "vite": "^6.0.5",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.0.6"
    }
}
