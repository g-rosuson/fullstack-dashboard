NODE_ENV=development
DEV_CLIENT_URL=http://localhost:3000
DEV_DOMAIN=localhost
ACCESS_TOKEN_SECRET=test-access-token-secret
REFRESH_TOKEN_SECRET=test-refresh-token-secret
# The MongoDB Node driver may treat the URI as a replica-set seed and run topology discovery; integration uses one local mongod.
# directConnection=true forces a single-server connection to 127.0.0.1 (no member discovery)—matches standalone mongod on the host.
MONGO_URI=mongodb://127.0.0.1:27017/test?directConnection=true
MONGO_DB_NAME=test-db-integration
MONGO_JOBS_COLLECTION_NAME=test-jobs-collection-integration
MONGO_USER_COLLECTION_NAME=test-user-collection-integration
ENABLE_HTTP_RATE_LIMIT=false
ENABLE_LOGGING=false
