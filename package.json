{
    "name": "mern-authentication",
    "version": "1.0.0",
    "scripts": {
        "prepare": "husky install",
        "type-check": "tsc --noEmit",
        "format": "prettier . --write --ignore-path .prettierignore",
        "start:dev": "bash start.sh dev",
        "start:prod": "bash start.sh prod",
        "reset:dev": "bash reset.sh dev",
        "reset:prod": "bash reset.sh prod"
    },
    "devDependencies": {
        "@commitlint/cli": "18.6.0",
        "@commitlint/config-conventional": "18.6.0",
        "husky": "9.0.10",
        "prettier": "3.2.5"
    }
}
